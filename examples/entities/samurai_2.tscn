[sub_resource type="GDScript" id="GDScript_tggw7"]
script/source = "extends Entity

@onready var MeleeBuffer = $MeleeBuffer
@onready var ProjectileLauncher = $ProjectileAttack

func _process(_delta: float) -> void: ANM_P_Animation_Tree.set(\"parameters/conditions/melee\", MeleeBuffer.buffer)
func melee(): MeleeBuffer.start()
func projectile(): start_anim(\"shoot\")
"

